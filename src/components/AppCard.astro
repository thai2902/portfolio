---
import type { CollectionEntry } from "astro:content";

interface Props {
  app: CollectionEntry<"apps">;
}

const { app } = Astro.props;
const { data } = app;

const isComingSoon = data.status.toLowerCase().includes("coming soon");
const isFeatured = data.featured === true;
---

<article class={`group flex flex-col h-full bg-white border border-gray-200 transition-colors duration-300 ${isFeatured ? "md:col-span-2" : ""} ${isComingSoon ? "opacity-50" : "hover:border-black cursor-pointer"}`}>
  {
    (() => {
      const fallbackImages = [
        "https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?auto=format&fit=crop&w=800&q=80",
        "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80",
        "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80",
        "https://images.unsplash.com/photo-1618761714954-0b8cd0026356?auto=format&fit=crop&w=800&q=80",
        "https://images.unsplash.com/photo-1555421689-491a97ff2040?auto=format&fit=crop&w=800&q=80",
      ];
      const imageSrc = fallbackImages[data.id % fallbackImages.length];

      return (
        <div class={`relative w-full bg-gray-100 mb-5 overflow-hidden border-b border-gray-100 ${isFeatured ? "h-64 sm:h-80 md:h-[400px]" : "h-64"}`}>
          <img
            src={imageSrc}
            alt={data.title}
            class={`w-full h-full object-cover transition-all duration-700 ${!isComingSoon ? "group-hover:scale-105" : "opacity-50"}`}
            loading="lazy"
          />
        </div>
      );
    })()
  }

  <div class="flex-grow flex flex-col p-5">
    <div class="mb-3">
      <h2 class="text-lg font-semibold leading-tight text-black mb-1">
        {data.title}
      </h2>
      <div class="text-xs font-medium text-gray-500 uppercase tracking-wider">
        {data.status}
      </div>
    </div>

    {
      !isComingSoon && data.short && (
        <p class="text-gray-600 text-sm leading-relaxed mb-4">
          {data.short}
        </p>
      )
    }
    
    {
      !isComingSoon && data.features && (
        <p class="text-gray-500 text-xs leading-relaxed line-clamp-2">
          {data.features}
        </p>
      )
    }
  </div>
</article>
