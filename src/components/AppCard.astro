---
import type { CollectionEntry } from "astro:content";

interface Props {
  app: CollectionEntry<"apps">;
}

const { app } = Astro.props;
const { data } = app;

const isComingSoon = data.status.toLowerCase().includes("coming soon");
---

<article
  class={`group relative flex flex-col h-full overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition-all duration-300 ${isComingSoon ? "opacity-50 hover:opacity-100" : "hover:-translate-y-1 hover:shadow-lg cursor-pointer"}`}
>
  <div class="p-6 flex-grow flex flex-col">
    <div class="flex items-start justify-between gap-4">
      <h2
        class={`text-xl font-semibold leading-tight transition-colors duration-200 ${!isComingSoon ? "group-hover:text-[var(--color-accent)]" : ""}`}
      >
        <!-- <span class="text-gray-400 font-medium mr-1"
          >{data.id.toString().padStart(2, "0")}.</span
        > -->
        {data.title}
      </h2>
    </div>
    {
      isComingSoon && (
        <div>
          <span
            class={`shrink-0 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold ${isComingSoon ? "bg-gray-100 text-gray-600" : "bg-blue-50 text-[var(--color-accent)] border border-blue-100"}`}
          >
            {data.status}
          </span>
        </div>
      )
    }

    {
      !isComingSoon && data.short && (
        <p class="text-[var(--color-secondary)] mb-6 text-sm leading-relaxed">
          {data.short}
        </p>
      )
    }

    {
      !isComingSoon && (
        <div class="space-y-4 mt-auto">
          {data.features && (
            <div class="text-sm">
              <strong class="block font-medium text-gray-900 mb-1">
                Key Features
              </strong>
              <span class="text-gray-600 line-clamp-2" title={data.features}>
                {data.features}
              </span>
            </div>
          )}
        </div>
      )
    }
  </div>

  {
    (() => {
      const fallbackImages = [
        "https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?auto=format&fit=crop&w=800&q=80",
        "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80",
        "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80",
        "https://images.unsplash.com/photo-1618761714954-0b8cd0026356?auto=format&fit=crop&w=800&q=80",
        "https://images.unsplash.com/photo-1555421689-491a97ff2040?auto=format&fit=crop&w=800&q=80",
      ];
      const imageSrc = fallbackImages[data.id % fallbackImages.length];

      return (
        <div class="relative h-48 w-full bg-slate-50 overflow-hidden border-t border-gray-100 mt-auto flex-shrink-0 group-hover:bg-slate-100 transition-colors">
          <img
            src={imageSrc}
            alt={data.title}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
        </div>
      );
    })()
  }
</article>
