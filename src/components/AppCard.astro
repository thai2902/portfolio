---
import type { CollectionEntry } from "astro:content";

interface Props {
  app: CollectionEntry<"apps">;
}

const { app } = Astro.props;
const { data } = app;

const isComingSoon = data.status.toLowerCase().includes("coming soon");
const isFeatured = data.featured === true;
function getYoutubeVideoId(url?: string) {
  if (!url) return null;
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
  const match = url.match(regExp);
  return (match && match[2].length === 11) ? match[2] : null;
}
const ytId = getYoutubeVideoId(data.videoUrl);
const embedUrl = ytId ? `https://www.youtube.com/embed/${ytId}` : null;
const ytThumbnail = ytId ? `https://img.youtube.com/vi/${ytId}/hqdefault.jpg` : null;

const fallbackImages = [
  "https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?auto=format&fit=crop&w=800&q=80",
  "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80",
  "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80",
  "https://images.unsplash.com/photo-1618761714954-0b8cd0026356?auto=format&fit=crop&w=800&q=80",
  "https://images.unsplash.com/photo-1555421689-491a97ff2040?auto=format&fit=crop&w=800&q=80",
];
const imageSrc = (data.gallery && data.gallery.length > 0) ? data.gallery[0] : fallbackImages[data.id % fallbackImages.length];

const galleryThumbs = [];
if (ytThumbnail) galleryThumbs.push({ type: 'video', src: ytThumbnail, fullSrc: embedUrl });

if (data.gallery && data.gallery.length > 0) {
  data.gallery.forEach(img => {
    galleryThumbs.push({ type: 'image', src: img, fullSrc: img });
  });
} else {
  galleryThumbs.push({ type: 'image', src: imageSrc, fullSrc: imageSrc });
}
const displayThumbs = galleryThumbs.slice(0, 5);
---

<a 
  href={`/apps/${app.id}`}
  data-category={data.category?.toLowerCase() || 'other'}
  class={`block app-card group flex flex-col h-full bg-white border border-gray-200 transition-colors duration-300 ${isFeatured ? "md:col-span-2" : ""} ${isComingSoon ? "opacity-50" : "hover:border-black cursor-pointer"}`}
>
  <div class={`card-media-container relative w-full bg-gray-100 overflow-hidden border-b border-gray-100 ${isFeatured ? "h-64 sm:h-80 md:h-[400px]" : "h-64"}`} data-video-url={embedUrl ? `${embedUrl}?autoplay=1&mute=1&controls=0&rel=0&modestbranding=1` : ''}>
    <img
      src={imageSrc}
      alt={data.title}
      class={`card-main-img w-full h-full object-cover transition-all duration-700 ${!isComingSoon ? "group-hover:scale-105" : "opacity-50"}`}
      loading="lazy"
    />
    {embedUrl && !isComingSoon && (
      <iframe
        class="card-video-iframe absolute top-0 left-0 w-full h-full bg-black opacity-0 transition-opacity duration-300 pointer-events-none"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      ></iframe>
    )}
  </div>

  <div class="flex-grow flex flex-col p-5 pt-4">
    {!isComingSoon && displayThumbs.length > 1 && (
      <div class="flex gap-2 mb-3">
        {displayThumbs.map((thumb, index) => (
          <div 
            class={`card-thumb-item w-8 h-8 rounded-sm overflow-hidden border ${index === 0 ? 'border-black' : 'border-gray-200 hover:border-gray-400'} transition-colors relative`}
            data-src={thumb.fullSrc}
            data-type={thumb.type}
          >
            <img src={thumb.src} class="w-full h-full object-cover" />
            {thumb.type === 'video' && (
              <div class="absolute inset-0 flex items-center justify-center bg-black/20">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M4 4l12 6-12 6z" /></svg>
              </div>
            )}
          </div>
        ))}
      </div>
    )}
    
    <div class="mb-3">
      <h2 class="text-lg font-semibold leading-tight text-black mb-1">
        {data.title}
      </h2>
      <div class="flex items-center gap-2">
        <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">
          {data.category}
        </span>
        <span class="text-gray-300">•</span>
        <span class="text-xs font-medium text-gray-400 capitalize">
          {data.status.toLowerCase()}
        </span>
      </div>
    </div>

    {
      !isComingSoon && data.short && (
        <p class="text-gray-600 text-sm leading-relaxed mb-4">
          {data.short}
        </p>
      )
    }
    
    {
      !isComingSoon && data.features && (
        <p class="text-gray-500 text-xs leading-relaxed line-clamp-2">
          {data.features}
        </p>
      )
    }
    }
  </div>
</a>

<script>
  function initAppCards() {
    const cards = document.querySelectorAll('.app-card');
    
    cards.forEach(card => {
      const mediaContainer = card.querySelector('.card-media-container');
      const mainImg = card.querySelector('.card-main-img');
      const videoIframe = card.querySelector('.card-video-iframe') as HTMLIFrameElement;
      const videoUrl = mediaContainer?.getAttribute('data-video-url');
      const thumbs = card.querySelectorAll('.card-thumb-item');
      
      let hoverTimeout: any;
      
      if (mediaContainer && videoIframe && videoUrl) {
        mediaContainer.addEventListener('mouseenter', () => {
          hoverTimeout = setTimeout(() => {
            videoIframe.src = videoUrl;
            videoIframe.style.opacity = '1';
            if (mainImg) (mainImg as HTMLElement).style.opacity = '0';
          }, 300);
        });
        
        mediaContainer.addEventListener('mouseleave', () => {
          clearTimeout(hoverTimeout);
          videoIframe.style.opacity = '0';
          if (mainImg) (mainImg as HTMLElement).style.opacity = '1';
          setTimeout(() => {
            videoIframe.removeAttribute('src');
          }, 300);
        });
      }
      
      if (thumbs.length > 0) {
        thumbs.forEach(thumb => {
          thumb.addEventListener('mouseenter', (e) => {
            const type = thumb.getAttribute('data-type');
            const src = thumb.getAttribute('data-src');
            
            thumbs.forEach(t => {
              t.classList.remove('border-black');
              t.classList.add('border-gray-200');
            });
            thumb.classList.remove('border-gray-200', 'hover:border-gray-400');
            thumb.classList.add('border-black');
            
            if (type === 'image' && mainImg && src) {
              (mainImg as HTMLImageElement).src = src;
              if (videoIframe) {
                clearTimeout(hoverTimeout);
                videoIframe.style.opacity = '0';
                videoIframe.removeAttribute('src');
                (mainImg as HTMLElement).style.opacity = '1';
              }
            } else if (type === 'video' && videoIframe && videoUrl) {
              videoIframe.src = videoUrl;
              videoIframe.style.opacity = '1';
              if (mainImg) (mainImg as HTMLElement).style.opacity = '0';
            }
          });
        });
      }
    });
  }
  
  initAppCards();
</script>
