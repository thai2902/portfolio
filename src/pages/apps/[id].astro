---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Cta from '../../components/Cta.astro';
import settingsData from '../../data/settings.json';

export async function getStaticPaths() {
  const apps = await getCollection('apps');
  return apps.map(app => ({
    params: { id: app.id },
    props: { app },
  }));
}

const { app } = Astro.props;
const { data } = app;
const { Content } = await render(app);

// Use same image logic for consistency
const fallbackImages = [
  "https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?auto=format&fit=crop&w=1200&q=80",
  "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=1200&q=80",
  "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1200&q=80",
  "https://images.unsplash.com/photo-1618761714954-0b8cd0026356?auto=format&fit=crop&w=1200&q=80",
  "https://images.unsplash.com/photo-1555421689-491a97ff2040?auto=format&fit=crop&w=1200&q=80",
];
const imageSrc = (data.gallery && data.gallery.length > 0) ? data.gallery[0] : fallbackImages[data.id % fallbackImages.length];

function getYoutubeVideoId(url?: string) {
  if (!url) return null;
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
  const match = url.match(regExp);
  return (match && match[2].length === 11) ? match[2] : null;
}
const ytId = getYoutubeVideoId(data.videoUrl);
const embedUrl = ytId ? `https://www.youtube.com/embed/${ytId}?autoplay=1&mute=1&controls=0&rel=0&modestbranding=1` : null;
const ytThumbnail = ytId ? `https://img.youtube.com/vi/${ytId}/hqdefault.jpg` : null;
---

<Layout 
  title={`${data.title} | Portfolio`}
  description={data.short || data.features || `Explore the ${data.title} project in my portfolio.`}
  image={imageSrc}
  type="article"
>
  <article class="max-w-5xl mx-auto px-4 py-12 lg:py-20">
    <!-- Back Navigation -->
    <a href="/#projects" class="inline-flex items-center text-sm font-medium text-gray-500 hover:text-black transition-colors mb-10">
      <span class="mr-2">&larr;</span> Back to Portfolio
    </a>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="px-3 py-1 bg-black text-white text-xs font-semibold uppercase tracking-wider">
          {data.category}
        </span>
        <span class="px-3 py-1 border border-gray-200 text-gray-600 text-xs font-medium uppercase tracking-wider">
          {data.status}
        </span>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 leading-[1.1] mb-6">
        {data.title}
      </h1>
      {data.short && (
        <p class="text-xl text-gray-500 font-light leading-relaxed max-w-3xl">
          {data.short}
        </p>
      )}
    </header>

    <!-- Product Gallery -->
    <div class="mb-16">
      <div class="relative w-full h-[40vh] min-h-[300px] md:h-[60vh] bg-gray-100 border border-gray-200 overflow-hidden mb-4">
        <img
          id="main-product-image"
          src={imageSrc}
          alt={data.title}
          class={`w-full h-full object-cover transition-opacity duration-200 ${embedUrl ? 'hidden' : ''}`}
        />
        {embedUrl && (
          <iframe
            id="main-product-video"
            src={embedUrl}
            class="absolute top-0 left-0 w-full h-full bg-black transition-opacity duration-200"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        )}
      </div>
      
      <div class="flex gap-3 overflow-x-auto pb-2 scrollbar-hide">
        <!-- Video Thumb (First) -->
        {embedUrl && ytThumbnail && (
          <button class="gallery-thumb relative flex-shrink-0 w-20 h-20 md:w-24 md:h-24 border-2 border-black focus:outline-none transition-colors overflow-hidden bg-black" data-type="video">
            <img src={ytThumbnail} alt="Video Thumbnail" class="w-full h-full object-cover opacity-60" />
            <div class="absolute inset-0 flex items-center justify-center">
              <svg class="w-8 h-8 text-white drop-shadow-md" fill="currentColor" viewBox="0 0 20 20"><path d="M4 4l12 6-12 6z" /></svg>
            </div>
          </button>
        )}
        <!-- Main Image Thumb (Fallback) -->
        {(!data.gallery || data.gallery.length === 0) && (
          <button class={`gallery-thumb flex-shrink-0 w-20 h-20 md:w-24 md:h-24 border-2 ${embedUrl ? 'border-transparent hover:border-gray-300' : 'border-black'} focus:outline-none transition-colors`} data-type="image" data-src={imageSrc}>
            <img src={imageSrc} alt="Thumbnail cover" class="w-full h-full object-cover" />
          </button>
        )}
        <!-- Gallery Images -->
        {data.gallery && data.gallery.map((img, index) => (
          <button class={`gallery-thumb flex-shrink-0 w-20 h-20 md:w-24 md:h-24 border-2 ${(!embedUrl && index === 0) ? 'border-black' : 'border-transparent hover:border-gray-300'} focus:outline-none transition-colors`} data-type="image" data-src={img}>
            <img src={img} alt={`Thumbnail ${index + 1}`} class="w-full h-full object-cover" />
          </button>
        ))}
      </div>
    </div>

    <!-- Content Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-20">
      
      <!-- Left Column: Main Content -->
      <div class="md:col-span-2 prose prose-lg prose-slate max-w-none">
        {data.why && (
          <div class="mb-10 p-6 bg-gray-50 border-l-4 border-black">
            <h3 class="text-lg font-semibold text-black mt-0 mb-2">Why this project?</h3>
            <p class="text-gray-700 m-0 text-base">{data.why}</p>
          </div>
        )}
        
        <h2 class="text-2xl font-bold text-black mb-4">Overview & Features</h2>
        <p class="text-gray-600 leading-relaxed mb-8">
          {data.features || "Detailed information about this project is currently being compiled. Stay tuned for more updates on features, technical stack, and outcomes."}
        </p>
        
        <!-- Render markdown body if exists -->
        <Content />
      </div>

      <!-- Right Column: Meta Sidebar -->
      <aside class="space-y-8">
        <div class="border-t border-gray-200 pt-6">
          <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Role</h4>
          <p class="font-medium text-black">Product Builder</p>
        </div>
        
        <div class="border-t border-gray-200 pt-6">
          <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Domain</h4>
          <p class="font-medium text-black">{data.category}</p>
        </div>
        
        {data.roi && (
          <div class="border-t border-gray-200 pt-6">
            <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Impact / ROI</h4>
            <p class="font-medium text-black">{data.roi}</p>
          </div>
        )}
        
        <div class="border-t border-gray-200 pt-6">
          <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Status</h4>
          <p class="font-medium text-black">{data.status}</p>
        </div>
      </aside>
      
    </div>
  </article>

  <Cta />

  <footer class="py-12 text-center text-gray-400 text-sm">
    <p>&copy; {new Date().getFullYear()} {settingsData.portfolioOwner}. All rights reserved.</p>
  </footer>
</Layout>

<script>
  function initGallery() {
    const mainImage = document.getElementById('main-product-image') as HTMLImageElement;
    const mainVideo = document.getElementById('main-product-video') as HTMLIFrameElement;
    const thumbs = document.querySelectorAll('.gallery-thumb');
    
    if (!mainImage || thumbs.length === 0) return;
    
    thumbs.forEach(thumb => {
      thumb.addEventListener('click', (e) => {
        const btn = e.currentTarget as HTMLElement;
        const type = btn.getAttribute('data-type');
        
        // Cross-fade effect
        if (mainImage) mainImage.style.opacity = '0.5';
        if (mainVideo) mainVideo.style.opacity = '0.5';
        
        setTimeout(() => {
          if (type === 'video') {
            if (mainImage) mainImage.classList.add('hidden');
            if (mainVideo) {
              mainVideo.classList.remove('hidden');
              const currentSrc = mainVideo.src;
              if (currentSrc.includes('autoplay=0')) {
                 mainVideo.src = currentSrc.replace(/autoplay=0/g, 'autoplay=1');
              } else if (!currentSrc.includes('autoplay=1')) {
                 mainVideo.src = currentSrc + (currentSrc.includes('?') ? '&' : '?') + 'autoplay=1';
              }
              mainVideo.style.opacity = '1';
            }
          } else {
            const src = btn.getAttribute('data-src');
            if (mainVideo) {
              mainVideo.classList.add('hidden');
              const currentSrc = mainVideo.src;
              if (currentSrc.includes('autoplay=1')) {
                mainVideo.src = currentSrc.replace(/([?&])autoplay=1/g, '$1autoplay=0');
              }
            }
            if (mainImage) {
              mainImage.classList.remove('hidden');
              if (src) mainImage.src = src;
              mainImage.style.opacity = '1';
            }
          }
        }, 150);
        
        // Update borders
        thumbs.forEach(t => {
          t.classList.remove('border-black');
          t.classList.add('border-transparent');
        });
        btn.classList.remove('border-transparent');
        btn.classList.add('border-black');
      });
    });
  }
  
  // Run on first load
  initGallery();
</script>
